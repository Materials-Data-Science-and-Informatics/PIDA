# Artifacts: fdo-semantics  
# Artifacts Names: FAIR Digital Objects Mappings
# Resource location: https://codebase.helmholtz.cloud/hmc/hmc-public/hob/fdo-semantics/-/raw/main/mappings/Helmholtz-KIP-mappings.tsv

Options +FollowSymLinks
# Turn off MultiViews
Options -MultiViews

# Directive to ensure *.rdf files served as appropriate content type,
# if not present in main apache config


RewriteEngine on


#Gitlab project 
 
RewriteRule ^$ https://codebase.helmholtz.cloud/hmc/hmc-public/hob/fdo-semantics  [R=303,NE,L]

 
RewriteRule ^mappings$ https://codebase.helmholtz.cloud/hmc/hmc-public/hob/fdo-semantics/-/raw/main/mappings/Helmholtz-KIP-mappings.tsv  [R=303,L]

 
